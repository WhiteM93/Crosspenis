# /etc/systemd/system/crosspenis.service
# sudo systemctl daemon-reload && sudo systemctl enable crosspenis && sudo systemctl start crosspenis

[Unit]
Description=Crosspenis
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/crosspenis
EnvironmentFile=/home/YOUR_USER/crosspenis/.env
ExecStart=/home/YOUR_USER/crosspenis/venv/bin/python app.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

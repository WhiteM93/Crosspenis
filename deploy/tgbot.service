# systemd unit для TgBot. Размести в /etc/systemd/system/tgbot.service
# После правок: sudo systemctl daemon-reload && sudo systemctl enable tgbot && sudo systemctl start tgbot

[Unit]
Description=TgBot (Паша Техник)
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/tgbot
EnvironmentFile=/home/YOUR_USER/tgbot/.env
ExecStart=/home/YOUR_USER/tgbot/venv/bin/python bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
